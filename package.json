{
  "name": "mission-control",
  "version": "0.1.0",
  "description": "Web-based UI for managing SDLC workflows and interacting with Claude Code",
  "type": "module",
  "bin": {
    "mc": "dist/server/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "dev": "concurrently -n server,ui -c blue,green \"tsx watch --clear-screen=false src/cli.ts --dev --no-open\" \"vite\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start": "node dist/server/cli.js",
    "prepare": "node -e \"try{require('node-pty')}catch(e){console.log('node-pty: native module will compile on first use')}\""
  },
  "keywords": [
    "cli",
    "sdlc",
    "claude",
    "dashboard",
    "project-management"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.0.0",
    "marked": "^16.0.0",
    "mermaid": "^11.13.0",
    "node-pty": "^1.2.0-beta.12",
    "open": "^10.1.0",
    "react": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@chakra-ui/react": "^3.8.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@playwright/test": "^1.50.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.7",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "concurrently": "^9.1.2",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.0.0",
    "lucide-react": "^0.475.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7",
    "zustand": "^5.0.3"
  }
}
