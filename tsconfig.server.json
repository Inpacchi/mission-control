{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "outDir": "dist/server",
    "rootDir": "src",
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "src/cli.ts",
    "src/server/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/ui/**/*",
    "node_modules",
    "dist"
  ]
}
